{
    "name": "@brightlayer-ui/react-native-components",
    "version": "9.2.1",
    "author": "brightlayer-ui <brightlayer-ui@eaton.com>",
    "description": "Reusable React Native components for Brightlayer UI applications",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/etn-ccis/blui-react-native"
    },
    "keywords": [
        "react native",
        "components",
        "brightlayer-ui"
    ],
    "bugs": {
        "url": "https://github.com/etn-ccis/blui-react-native/issues"
    },
    "homepage": "https://github.com/etn-ccis/blui-react-native#readme",
    "license": "BSD-3-Clause",
    "main": "./index.js",
    "publishConfig": {
        "main": "./index.js"
    },
    "type": "module",
    "module": "./index.js",
    "types": "./index.d.ts",
    "exports": {
        ".": {
            "import": "./index.js",
            "require": "./index.js"
        }
    },
    "scripts": {
        "build": "bash ./scripts/buildComponents.sh",
        "test": "jest",
        "test:watch": "jest --watch",
        "coverage": "yarn test --coverage --watchAll=false",
        "verify-build": "tsc --noEmit",
        "publish:package": "cd dist && set npm_config_yes=true && npx -p @brightlayer-ui/publish blui-publish",
        "tag:package": "cd dist && set npm_config_yes=true && npx -p @brightlayer-ui/tag blui-tag -s -blui-react-native-component-library"
    },
    "dependencies": {
        "@brightlayer-ui/react-native-themes": "8.1.0",
        "@callstack/react-theme-provider": "^3.0.9",
        "@types/prop-types": "^15.7.15",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "color": "^5.0.3",
        "prop-types": "^15.8.1",
        "react-native-collapsible": "^1.6.2",
        "react-native-keyboard-aware-scroll-view": "^0.9.5",
        "react-native-modal": "^13.0.2",
        "react-native-reanimated": "^4.2.2",
        "react-native-worklets": "^0.7.4"
    },
    "peerDependencies": {
        "@brightlayer-ui/react-native-vector-icons": "^3.1.0",
        "@react-native-vector-icons/material-design-icons": "^12.4.1",
        "@react-native-vector-icons/material-icons": "^12.4.1",
        "react": "^19.2.4",
        "react-native": "~0.84.0",
        "react-native-paper": "^5.15.0",
        "react-native-safe-area-context": "^5.7.0",
        "react-native-vector-icons": "^10.3.0"
    },
    "devDependencies": {
        "babel-jest": "^30.3.0",
        "@brightlayer-ui/eslint-config": "^4.0.1",
        "@brightlayer-ui/icons-svg": "^1.16.0",
        "@brightlayer-ui/prettier-config": "^1.0.3",
        "@brightlayer-ui/react-native-vector-icons": "^3.1.0",
        "@faker-js/faker": "^10.3.0",
        "@react-native-vector-icons/material-design-icons": "^12.4.1",
        "@react-native-vector-icons/material-icons": "^12.4.1",
        "@react-native/babel-preset": "^0.84.0",
        "@testing-library/react-native": "^13.3.3",
        "@types/color": "^4.2.0",
        "@types/jest": "^30.0.0",
        "@types/node": "^25.3.1",
        "@types/react-native-collapsible": "^0.11.0",
        "@types/react-test-renderer": "^19.1.0",
        "@typescript-eslint/eslint-plugin": "^8.56.1",
        "@typescript-eslint/parser": "8.56.1",
        "eslint": "^10.0.2",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-react": "^7.37.5",
        "identity-obj-proxy": "^3.0.0",
        "jest": "^30.2.0",
        "prettier": "^3.8.1",
        "react": "^19.2.4",
        "react-native": "~0.84.0",
        "react-native-paper": "^5.15.0",
        "react-native-safe-area-context": "5.7.0",
        "react-native-svg": "^15.15.3",
        "react-native-vector-icons": "^10.3.0",
        "react-test-renderer": "^19.2.4",
        "ts-jest": "^29.4.6",
        "tsc-esm-fix": "^3.1.2",
        "typescript": "5.9.3"
    },
    "directories": {
        "doc": "../docs"
    }
}
